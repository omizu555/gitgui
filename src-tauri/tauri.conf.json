{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "GitGUI",
  "version": "0.1.0",
  "identifier": "com.gitgui.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GitGUI",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
